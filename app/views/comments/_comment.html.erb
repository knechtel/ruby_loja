<div id="<%= dom_id comment %>" class="comment-card">

  <div class="comment-header">
    <div class="comment-avatar"></div>
    <div class="comment-user">
      <strong>@usuario</strong>
      <div class="comment-post-ref">
        em <%= comment.post.title %>
      </div>
    </div>
  </div>

  <div class="comment-body">
    <%= comment.body %>
  </div>

</div>

<style>
  .comment-card {
    background: #fff;
    border: 1px solid #dbdbdb;
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 12px;
  }

  .comment-header {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
  }

  .comment-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #ddd;
    margin-right: 10px;
  }

  .comment-user {
    font-size: 14px;
  }

  .comment-post-ref {
    font-size: 12px;
    color: gray;
  }

  .comment-body {
    font-size: 14px;
    line-height: 1.4;
  }
</style>