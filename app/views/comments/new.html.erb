<style>
  body {
    background-color: #fafafa;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  }

  .insta-container {
    max-width: 400px;
    margin: 60px auto;
  }

  .insta-card {
    background: #fff;
    border: 1px solid #dbdbdb;
    border-radius: 8px;
    padding: 30px;
    text-align: center;
  }

  .insta-title {
    font-size: 22px;
    font-weight: 500;
    margin-bottom: 20px;
  }

  .insta-link {
    display: inline-block;
    margin-top: 15px;
    color: #0095f6;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
  }

  .insta-link:hover {
    text-decoration: underline;
  }
</style>

<div class="insta-container">

  <% content_for :title, "New comment" %>

  <div class="insta-card">
    <div class="insta-title">Novo Comentário</div>

    <%= render "form", comment: @comment %>

    <%= link_to "Voltar", comments_path, class: "insta-link" %>
  </div>

</div>