<style>
  body {
    background-color: #fafafa;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  }

  .insta-container {
    max-width: 500px;
    margin: 50px auto;
  }

  .insta-card {
    background: #fff;
    border: 1px solid #dbdbdb;
    border-radius: 8px;
    padding: 20px;
  }

  .insta-header {
    display: flex;
    align-items: center;
    margin-bottom: 15px;
  }

  .insta-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #ddd;
    margin-right: 10px;
  }

  .insta-username {
    font-weight: 600;
    font-size: 14px;
  }

  .insta-body {
    font-size: 15px;
    margin-bottom: 10px;
  }

  .insta-post-ref {
    font-size: 13px;
    color: gray;
  }

  .insta-actions {
    margin-top: 15px;
    text-align: center;
  }

  .insta-link {
    color: #0095f6;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    margin: 0 5px;
  }

  .insta-link:hover {
    text-decoration: underline;
  }

  .insta-delete {
    margin-top: 10px;
  }

  .insta-delete input {
    background-color: #ed4956;
    border: none;
    color: white;
    padding: 8px 12px;
    border-radius: 4px;
    cursor: pointer;
  }

  .insta-delete input:hover {
    background-color: #c13545;
  }

  .notice {
    color: green;
    text-align: center;
    margin-bottom: 15px;
  }
</style>

<div class="insta-container">

  <p class="notice"><%= notice %></p>

  <div class="insta-card">

    <div class="insta-header">
      <div class="insta-avatar"></div>
      <div class="insta-username">@usuario</div>
    </div>

    <div class="insta-body">
      <%= @comment.body %>
    </div>

    <div class="insta-post-ref">
      em <strong><%= @comment.post.title %></strong>
    </div>

    <%# Mantém render caso queira mais campos %>
    <%= render @comment %>

    <div class="insta-actions">
      <%= link_to "Editar", edit_comment_path(@comment), class: "insta-link" %> |
      <%= link_to "Voltar", comments_path, class: "insta-link" %>
    </div>

    <div class="insta-delete">
      <%= button_to "Excluir", @comment, method: :delete %>
    </div>

  </div>

</div>