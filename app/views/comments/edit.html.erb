<style>
  body {
    background-color: #fafafa;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  }

  .insta-container {
    max-width: 400px;
    margin: 60px auto;
  }

  .insta-card {
    background: #fff;
    border: 1px solid #dbdbdb;
    border-radius: 8px;
    padding: 30px;
    text-align: center;
  }

  .insta-title {
    font-size: 22px;
    font-weight: 500;
    margin-bottom: 20px;
  }

  .insta-links {
    margin-top: 15px;
  }

  .insta-link {
    color: #0095f6;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    margin: 0 5px;
  }

  .insta-link:hover {
    text-decoration: underline;
  }
</style>

<div class="insta-container">

  <% content_for :title, "Editing comment" %>

  <div class="insta-card">
    <div class="insta-title">Editar Comentário</div>

    <%= render "form", comment: @comment %>

    <div class="insta-links">
      <%= link_to "Ver comentário", @comment, class: "insta-link" %> |
      <%= link_to "Voltar", comments_path, class: "insta-link" %>
    </div>
  </div>

</div>